STRIPE_SECRET_KEY=sk_test_xxx_replace_with_yours
STRIPE_WEBHOOK_SECRET=whsec_xxx_optional
PORT=3000

# 万里汇 WorldFirst（与万里汇技术对接后获取）
WORLDFIRST_CLIENT_ID=你的Client-Id
WORLDFIRST_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# 或使用密钥文件路径（二选一）：
# WORLDFIRST_PRIVATE_KEY_PATH=./keys/worldfirst_private.pem
WORLDFIRST_DOMAIN=na
# 公网访问时的站点地址，用于支付回调与跳转（本地测试可留空，默认 http://localhost:PORT）
# BASE_URL=https://your-domain.com
